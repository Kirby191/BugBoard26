@startuml
left to right direction

' --- TEMA ---
skinparam backgroundColor white
skinparam defaultFontColor black

skinparam actor {
    BackgroundColor white
    BorderColor black
}

skinparam usecase {
    BackgroundColor #F4F6F8
    BorderColor #2C3E50
    FontColor black
}

skinparam rectangle {
    BorderColor black
    FontColor black
}


skinparam arrow {
    Color #333333
    FontColor black
}

' --- ATTORI ---
actor "Utente" as Utente
actor "Amministratore" as Admin

' Assicura che Admin sia posizionato sopra Utente
Admin -up-|> Utente

' --- USE CASE ---
rectangle "BugBoard26" {

    usecase "Creare Utenza" as UC_CreareUtenza
    usecase "Assegnare Issue" as UC_Assegnare
    usecase "Effettuare Login" as UC_Login
    usecase "Segnalare Issue" as UC_Segnalare
    usecase "Visualizzare Riepilogo" as UC_Riepilogo
    usecase "Modificare Issue" as UC_Modificare
    usecase "Visualizzare Cronologia" as UC_Cronologia

    ' Estensioni (dichiarate per essere posizionate a destra)
    usecase "Impostare Scadenza" as UC_Scadenza
    usecase "Allegare Immagine" as UC_AllegareImg

}

' --- ADMIN ---
Admin -- UC_CreareUtenza
Admin -- UC_Assegnare

' --- UTENTE ---
Utente -- UC_Login
Utente -- UC_Segnalare
Utente -- UC_Riepilogo
Utente -- UC_Modificare
Utente -- UC_Cronologia

' --- EXTEND ---
UC_Modificare <.. UC_Scadenza : <<extend>>
UC_Assegnare <.. UC_Scadenza : <<extend>>
UC_Segnalare <.. UC_AllegareImg : <<extend>>

@enduml